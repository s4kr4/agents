{
  "language": "japanese",
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/bin/claude-statusline"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(pwd *)",
      "Bash(lsmod *)",
      "Bash(w *)",
      "Bash(apt list *)",
      "Bash(docker compose *)",
      "Bash(tree *)",
      "Bash(jq *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git blame *)",
      "mcp__serena"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(git rebase *)",
      "Bash(psql *)",
      "Bash(mysql *)",
      "Bash(mongod *)",
      "Bash(npx *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Read(.env.*)",
      "Read(**/.env*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env*)",
      "Write(**/.env*)",
      "Write(**/secrets/**)"
    ],
    "ask": []
  }
}
